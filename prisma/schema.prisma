datasource db {
  provider = "postgresql"
}

generator client {
  provider     = "prisma-client-js"
}

enum Role {
  ADMIN
  DOCTOR
  NURSE
  RECEPTIONIST
  PATIENT
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Department {
  RECEPTION
  CONSULTATION
  PHARMACY
  MANAGEMENT
}

model User {
  id  String @id @default(uuid())
  email String @unique
  phoneNumber  String?  @unique @map("phone_number")
  passwordHash String @map("password_hash")
  role  Role  @default(PATIENT)
  isActive Boolean @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  employee Employee?
  patient Patient?
}

model Employee {
  id String @id @default(uuid())
  userId String @unique @map("user_id")
  fullName String @map("full_name")
  email String @unique 
  department Department?
  currentPatientLoad Int @default(0) @map("current_patient_load")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  patients Patient[] @relation("DoctorToPatient")
}

model Patient {
  id String @id @default(uuid())
  userId String? @unique @map("user_id")
  patientCode String @unique @map("patient_code")
  fullName String @map("full_name")
  dob DateTime? @db.Date
  gender Gender?
  address String? @db.Text
  assignedDoctorId String? @map("assigned_doctor_id")

  doctor Employee? @relation("DoctorToPatient", fields: [assignedDoctorId], references: [id], onDelete: SetNull)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}